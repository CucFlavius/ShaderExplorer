<Window x:Class="ShaderExplorer.App.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Variable" Height="180" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>

    <!-- Outer margin provides space for drop shadow -->
    <Border Margin="12"
            Background="{StaticResource Bg2Brush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.5" Color="#000000" />
        </Border.Effect>

        <Grid Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Style="{StaticResource TextSubheading}"
                       Margin="0,0,0,4">
                <Run Text="Rename Variable" />
            </TextBlock>

            <!-- Original name label -->
            <TextBlock Grid.Row="1"
                       Style="{StaticResource TextLabel}"
                       Margin="0,0,0,8">
                <Run Text="Original: " />
                <Run x:Name="OriginalNameRun"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource SyntaxNameBrush}" />
            </TextBlock>

            <!-- Input -->
            <TextBox x:Name="NewNameTextBox" Grid.Row="2"
                     FontSize="13"
                     Margin="0,0,0,14" />

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Margin="0,0,8,0"
                        Click="Cancel_Click" IsCancel="True" />
                <Button Content="Rename" Width="80"
                        Style="{StaticResource AccentButton}"
                        Click="Rename_Click" IsDefault="True" />
            </StackPanel>
        </Grid>
    </Border>
</Window>