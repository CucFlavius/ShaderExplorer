<Window x:Class="ShaderExplorer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:ShaderExplorer.App.ViewModels"
        xmlns:renderer="clr-namespace:ShaderExplorer.Renderer;assembly=ShaderExplorer.Renderer"
        Title="{Binding WindowTitle}" Height="800" Width="1700"
        Icon="pack://application:,,,/icon.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        DragEnter="Window_DragEnter" DragLeave="Window_DragLeave"
        Background="{StaticResource Bg0Brush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="4"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
    </Window.InputBindings>

    <!-- Root: 3-row Grid (titlebar, content, status) -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <!-- ═══ ROW 0: Custom Titlebar ═══ -->
        <Grid Grid.Row="0" Background="{StaticResource Bg0Brush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- App icon + title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0,0,0"
                        VerticalAlignment="Center">
                <Image Source="/assets/icon.png" Width="18" Height="18"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
                <TextBlock Text="ShaderExplorer"
                           FontFamily="{StaticResource AppFont}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FgPrimaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding ShaderFileName}"
                           FontFamily="{StaticResource AppFont}"
                           FontSize="12"
                           Foreground="{StaticResource FgSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0" />
            </StackPanel>

            <!-- Open button -->
            <Button Grid.Column="1"
                    Style="{StaticResource ToolbarButton}"
                    Command="{Binding OpenFileCommand}"
                    ToolTip="Open Shader (Ctrl+O)"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Margin="12,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE838;"
                               FontFamily="{StaticResource IconFont}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock Text="Open"
                               FontFamily="{StaticResource AppFont}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Recent files dropdown -->
            <Button x:Name="RecentFilesButton" Grid.Column="3"
                    Style="{StaticResource ToolbarButton}"
                    ToolTip="Recent Files"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="RecentFiles_Click"
                    Width="28" Height="28"
                    Padding="0"
                    Margin="2,0,0,0">
                <TextBlock Text="&#xE972;"
                           FontFamily="{StaticResource IconFont}"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>

            <!-- Shader info badge -->
            <Border Grid.Column="2"
                    Background="{StaticResource Bg2Brush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="6,2"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    x:Name="ShaderBadgeBorder">
                <TextBlock Text="{Binding ShaderInfoBadge}"
                           Style="{StaticResource TextCaption}"
                           Foreground="{StaticResource AccentBrush}" />
            </Border>

            <!-- Window controls -->
            <StackPanel Grid.Column="5" Orientation="Horizontal">
                <Button Style="{StaticResource ChromeButton}" Click="Minimize_Click">
                    <TextBlock Text="&#xE921;"
                               FontFamily="{StaticResource IconFont}"
                               FontSize="10" />
                </Button>
                <Button x:Name="MaximizeButton" Style="{StaticResource ChromeButton}" Click="Maximize_Click">
                    <TextBlock x:Name="MaximizeIcon"
                               Text="&#xE922;"
                               FontFamily="{StaticResource IconFont}"
                               FontSize="10" />
                </Button>
                <Button Style="{StaticResource ChromeCloseButton}" Click="Close_Click">
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="{StaticResource IconFont}"
                               FontSize="10" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══ ROW 1: Main Content ═══ -->
        <Grid Grid.Row="1" Margin="4,2,4,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="200" />
                <ColumnDefinition Width="7" />
                <ColumnDefinition Width="2*" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Sidebar + Editor -->
            <Border Grid.Column="0" Style="{StaticResource PanelCard}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeader}"
                            CornerRadius="6,6,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE943;"
                                       FontFamily="{StaticResource IconFont}"
                                       FontSize="12"
                                       Foreground="{StaticResource FgTertiaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="Decompiled HLSL"
                                       Style="{StaticResource TextLabel}" />
                        </StackPanel>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="SidebarColumn" Width="0" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- BLS Permutation Sidebar -->
                        <Border x:Name="PermutationSidebar" Grid.Column="0"
                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                BorderThickness="0,0,1,0"
                                Background="{StaticResource Bg1Brush}"
                                Visibility="Collapsed">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Padding="8,6"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1">
                                    <TextBlock Text="Permutations"
                                               Style="{StaticResource TextLabel}" />
                                </Border>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="PermutationList" />
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <!-- Editor area -->
                        <Grid Grid.Column="1">
                            <wv2:WebView2 x:Name="MonacoWebView" AllowExternalDrop="False"
                                          Visibility="Hidden" />
                            <!-- Loading indicator shown while Monaco initializes -->
                            <StackPanel x:Name="EditorLoadingOverlay"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <ProgressBar IsIndeterminate="True"
                                             Width="120" Height="2"
                                             Foreground="{StaticResource AccentBrush}"
                                             Background="{StaticResource Bg2Brush}"
                                             BorderThickness="0" />
                                <TextBlock Text="Loading editor..."
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource FgTertiaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                            <!-- Drop overlay — normally collapsed, shown during drag -->
                            <Border x:Name="EditorDropOverlay"
                                    Visibility="Collapsed"
                                    Background="#CC1E2027"
                                    AllowDrop="True"
                                    DragOver="DropOverlay_DragOver"
                                    Drop="DropOverlay_Drop"
                                    DragLeave="DropOverlay_DragLeave">
                                <Border BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="2"
                                        CornerRadius="8"
                                        Margin="24"
                                        Padding="20"
                                        Background="Transparent">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Opacity" Value="0.7" />
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="&#xE896;"
                                                   FontFamily="{StaticResource IconFont}"
                                                   FontSize="36"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,12" />
                                        <TextBlock Text="Drop shader file to decompile"
                                                   Style="{StaticResource TextSubheading}"
                                                   Foreground="{StaticResource FgSecondaryBrush}"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text=".cso  .dxbc  .fxo  .dxil  .bls  .bin  .mtl  .mtllib"
                                                   Style="{StaticResource TextCaption}"
                                                   Foreground="{StaticResource FgTertiaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </Border>
                        </Grid>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" />

            <!-- Right Panel: Viewport + Properties stacked -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" MinHeight="150" />
                    <RowDefinition Height="7" />
                    <RowDefinition Height="*" MinHeight="150" />
                </Grid.RowDefinitions>

                <!-- Top-Right: 3D Viewport -->
                <Border Grid.Row="0" Style="{StaticResource PanelCard}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeader}"
                                CornerRadius="6,6,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xF158;"
                                           FontFamily="{StaticResource IconFont}"
                                           FontSize="12"
                                           Foreground="{StaticResource FgTertiaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Preview"
                                           Style="{StaticResource TextLabel}" />
                            </StackPanel>
                        </Border>
                        <renderer:D3DImageViewport x:Name="Viewport" />
                    </DockPanel>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Row="1" Style="{StaticResource HorizontalSplitter}" />

                <!-- Bottom-Right: Properties -->
                <Border Grid.Row="2" Style="{StaticResource PanelCard}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeader}"
                                CornerRadius="6,6,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE946;"
                                           FontFamily="{StaticResource IconFont}"
                                           FontSize="12"
                                           Foreground="{StaticResource FgTertiaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Properties"
                                           Style="{StaticResource TextLabel}" />
                            </StackPanel>
                        </Border>
                        <TabControl x:Name="PropertiesTabControl">
                            <TabItem Header="Inputs/Outputs">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                                    <StackPanel x:Name="SignaturePanel">
                                        <TextBlock Text="Open a shader file to see inputs/outputs"
                                                   Foreground="{StaticResource FgTertiaryBrush}"
                                                   Margin="12,8" FontSize="11" />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Buffers">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                                    <StackPanel x:Name="BuffersPanel">
                                        <TextBlock Text="Open a shader file to see buffer layouts"
                                                   Foreground="{StaticResource FgTertiaryBrush}"
                                                   Margin="12,8" FontSize="11" />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Resources">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                                    <StackPanel x:Name="ResourcesPanel">
                                        <TextBlock Text="Open a shader file to see resource bindings"
                                                   Foreground="{StaticResource FgTertiaryBrush}"
                                                   Margin="12,8" FontSize="11" />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="Textures">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                                    <StackPanel x:Name="TexturesPanel">
                                        <TextBlock Text="No texture bindings"
                                                   Foreground="{StaticResource FgTertiaryBrush}"
                                                   Margin="12,8" FontSize="11" />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══ ROW 2: Status Strip ═══ -->
        <Border Grid.Row="2"
                Background="{StaticResource Bg0Brush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}"
                           Style="{StaticResource TextCaption}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left" />
                <TextBlock Text="{Binding ShaderFormatText}"
                           Style="{StaticResource TextCaption}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</Window>